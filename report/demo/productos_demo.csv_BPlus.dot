digraph BPlusTree {
    rankdir=TB;
    node [shape=record fontname="Arial" fontsize=10];
    edge [arrowsize=0.7];
    node0 [style=filled fillcolor=lightyellow label="<p0> ↓|<f0> Carnes|<p1> ↓|<f1> Granos|<p2> ↓|<f2> Lacteos|<p3> ↓|<f3> Panaderia|<p4> ↓"];
    leaf1 [style=filled fillcolor=lightblue label="<e0> Bebidas\nBebida Energia|<e1> Bebidas\nCafe Molido|<e2> Bebidas\nRefresco Cola|<e3> Bebidas\nAgua Mineral|<next> →"];
    node0:p0 -> leaf1;
    leaf2 [style=filled fillcolor=lightblue label="<e0> Carnes\nSalchicha Frankfurt|<e1> Congelados\nHelado Vainilla|<e2> Frutas\nMango Ataulfo|<e3> Frutas\nNaranja|<e4> Frutas\nUva Verde|<next> →"];
