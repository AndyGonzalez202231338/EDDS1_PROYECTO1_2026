    leaf1:next -> leaf2:w [style=dashed color="#888888" arrowsize=0.6];
    leaf2:next -> leaf3:w [style=dashed color="#888888" arrowsize=0.6];
    leaf3:next -> leaf4:w [style=dashed color="#888888" arrowsize=0.6];
    leaf4:next -> leaf5:w [style=dashed color="#888888" arrowsize=0.6];
}
