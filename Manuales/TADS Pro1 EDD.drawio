ada sobre catalog&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Courier New&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;promptProduct() : Product //&lt;/span&gt;&lt;span style=&quot;font-size: 10px; text-wrap-mode: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 10px; text-wrap-mode: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;retorna Product con campos leidos de campo a campo&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
